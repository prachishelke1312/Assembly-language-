%macro IO 4
mov rax,%1
mov rdi,%2
mov rsi,%3
mov rdx,%4
syscall
%endmacro

section .data
msg1 db "Enter 5 numbers:",10
len1 equ $-msg1

msg2 db 10,"Numbers are:",10
len2 equ $-msg2

section .bss
array resb 85
temp resb 17

section .text
global _start

_start:

IO 1,1,msg1,len1

mov rcx,5
mov rbx,0

input:
IO 0,0,temp,17

mov rsi,temp
mov rdi,array
add rdi,rbx

mov rdx,17

copy1:
mov al,[rsi]
mov [rdi],al
inc rsi
inc rdi
dec rdx
jnz copy1

add rbx,17
loop input

IO 1,1,msg2,len2

mov rcx,5
mov rbx,0

display:
mov rsi,array
add rsi,rbx

IO 1,1,rsi,17

add rbx,17
loop display

mov rax,60
xor rdi,rdi
syscall

